{% set flashes = app.flashes %}
{% for label, messages in flashes %}
    {% for message in messages %}
        <div x-data="{ open: true }"
             x-show="open"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 scale-95"
             data-testid="flash-message"
             class="mb-4 p-3 rounded-md text-sm {{
                 label == 'success' ? 'bg-green-50 text-green-700 border border-green-200' :
                 (label == 'warning' ? 'bg-yellow-50 text-yellow-700 border border-yellow-200' :
                 'bg-red-50 text-red-700 border border-red-200')
             }}"
             role="alert">
            <div class="flex items-center justify-between gap-3">
                <span class="flex-1">{{ message }}</span>
                <button type="button"
                        @click="open = false"
                        aria-label="{{ 'flash.dismiss'|trans }}"
                        data-testid="flash-dismiss-button"
                        class="flex-shrink-0 text-gray-400 hover:text-gray-600 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 rounded p-0.5 cursor-pointer">
                    <svg class="h-5 w-5"
                         xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 0 20 20"
                         fill="currentColor"
                         aria-hidden="true">
                        <path fill-rule="evenodd"
                              d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                              clip-rule="evenodd" />
                    </svg>
                </button>
            </div>
        </div>
    {% endfor %}
{% endfor %}
