{% extends 'base.html.twig' %}
{% import 'macros/ui.html.twig' as ui %}

{% block title %}{{ 'dashboard.title'|trans }}{% endblock %}

{% block body %}
<div x-data="{ searchId: '', dropdownOpen: false }" data-turbo-permanent class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {% include 'components/flash_messages.html.twig' %}

    <div class="flex w-full items-center mb-8">
        <h1 data-testid="dashboard-title" class="text-3xl font-bold text-gray-900 flex-1">{{ 'dashboard.title'|trans }}</h1>
        <div class="flex gap-2">
            {% set currentLocale = app.request.locale|default('cs') %}
            {% if currentLocale == 'cs' %}
                <span data-testid="locale-switch-cs" class="px-3 py-1 rounded-full text-xs font-medium bg-emerald-700 text-white">{{ 'locale.switcher.cs'|trans }}</span>
                <a href="{{ path('locale_switch', {locale: 'en'}) }}" data-turbo="false" data-testid="locale-switch-en"
                   class="px-3 py-1 rounded-full text-xs font-medium bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors cursor-pointer">
                    {{ 'locale.switcher.en'|trans }}
                </a>
            {% else %}
                <a href="{{ path('locale_switch', {locale: 'cs'}) }}" data-turbo="false" data-testid="locale-switch-cs"
                   class="px-3 py-1 rounded-full text-xs font-medium bg-gray-200 text-gray-700 hover:bg-gray-300 transition-colors cursor-pointer">
                    {{ 'locale.switcher.cs'|trans }}
                </a>
                <span data-testid="locale-switch-en" class="px-3 py-1 rounded-full text-xs font-medium bg-emerald-700 text-white">{{ 'locale.switcher.en'|trans }}</span>
            {% endif %}
        </div>
    </div>

    <section data-testid="control-panel" class="bg-white rounded-lg shadow p-6 mb-8" aria-label="{{ 'dashboard.control_panel'|trans }}">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">{{ 'dashboard.control_panel'|trans }}</h2>

        <div data-testid="system-health" class="mb-6">
            <h3 class="text-sm font-medium text-gray-600 mb-2">{{ 'dashboard.system_health'|trans }}</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {% for service, healthy in healthStatus %}
                <div data-testid="health-service-{{ service|lower }}" class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg border border-gray-200">
                    {{ ui.led(healthy) }}
                    <div>
                        <span class="text-sm font-medium text-gray-900">{{ ('health.service.' ~ service)|trans }}</span>
                        <span class="text-xs {{ healthy ? 'text-green-600' : 'text-red-600' }}">
                            {{ healthy ? 'health.status.connected'|trans : 'health.status.disconnected'|trans }}
                        </span>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        <div data-testid="data-generation" class="mb-6">
            <div class="flex items-center gap-3">
                <h3 class="text-sm font-medium text-gray-600 w-52">{{ 'dashboard.data_generation'|trans }}</h3>
                <form method="post" action="{{ path('dashboard_seed') }}"
                      x-data="{ seeding: false }"
                      @submit="seeding = true">
                    <input type="hidden" name="_token" value="{{ csrf_token('seed') }}">
                    <input type="hidden" name="count" value="1000">
                    <button data-testid="generate-data-btn" type="submit"
                            :disabled="seeding"
                            class="bg-emerald-700 text-white px-4 py-2 rounded-lg hover:bg-emerald-800 disabled:opacity-50 disabled:cursor-not-allowed transition-colors text-sm cursor-pointer">
                        <span x-show="!seeding">{{ 'dashboard.generate_data'|trans }}</span>
                        <span x-show="seeding" class="flex items-center gap-2">
                            <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            {{ 'dashboard.seeding'|trans }}
                        </span>
                    </button>
                </form>
            </div>
        </div>

        <div data-testid="configuration">
            <h3 class="text-sm font-medium text-gray-600 mb-2">{{ 'dashboard.configuration'|trans }}</h3>
            <div class="space-y-3">
                {% for key, options in allToggleOptions %}
                    {% set configKey = key == 'ACTIVE_PRODUCT_SOURCE' ? 'source' : (key == 'ACTIVE_CACHE_DRIVER' ? 'cache' : 'counter') %}
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-mono text-gray-500 w-52">{{ ('toggle.label.' ~ key|lower)|trans }}</span>
                        <div class="flex gap-1" role="group" aria-label="{{ key }} toggle">
                            {% for option in options %}
                                {% set isActive = currentConfig[configKey] == option %}
                                {% set isAvailable = option in availableToggles[key] %}
                                {% if isAvailable %}
                                    <form method="post" action="{{ path('dashboard_toggle') }}" class="inline" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle') }}">
                                        <input type="hidden" name="key" value="{{ key }}">
                                        <input type="hidden" name="value" value="{{ option }}">
                                        <button data-testid="toggle-{{ key|lower }}-{{ option|lower }}" type="submit"
                                            class="px-3 py-1 rounded-full text-xs font-medium transition-colors cursor-pointer
                                                   {{ isActive ? 'bg-emerald-700 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' }}">
                                            {{ ('toggle.value.' ~ option|lower)|trans }}
                                        </button>
                                    </form>
                                {% else %}
                                    <button data-testid="toggle-{{ key|lower }}-{{ option|lower }}" type="button" disabled
                                        title="{{ 'toggle.unavailable.redis'|trans }}"
                                        class="px-3 py-1 rounded-full text-xs font-medium transition-colors opacity-50 cursor-not-allowed
                                               {{ isActive ? 'bg-emerald-700 text-white' : 'bg-gray-100 text-gray-400' }}">
                                        {{ ('toggle.value.' ~ option|lower)|trans }}
                                    </button>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section data-testid="search-section" class="bg-white rounded-lg shadow p-6 mb-8" aria-label="{{ 'dashboard.search'|trans }}">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">{{ 'dashboard.search'|trans }}</h2>

        <div class="flex gap-3 items-end">
            <div class="relative flex-1">
                <label for="search-input" class="sr-only">{{ 'dashboard.product_uuid'|trans }}</label>
                <input data-testid="search-input" type="text" id="search-input"
                       x-model="searchId"
                       @focus="dropdownOpen = true"
                       @click.away="dropdownOpen = false"
                       placeholder="{{ 'dashboard.search_placeholder'|trans }}"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 font-mono text-sm">
                <ul x-show="dropdownOpen" x-transition
                    class="absolute z-10 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-48 overflow-y-auto">
                    {% for id in productIds %}
                    <li @click="searchId = '{{ id }}'; dropdownOpen = false"
                        class="px-4 py-2 cursor-pointer hover:bg-gray-100 text-xs font-mono truncate">
                        {{ id }}
                    </li>
                    {% endfor %}
                </ul>
            </div>

            <button data-testid="search-button" @click="document.getElementById('search-result').src = '/product/' + searchId"
                    :disabled="!searchId"
                    class="bg-emerald-700 text-white px-6 py-2 rounded-lg hover:bg-emerald-800 disabled:opacity-50 disabled:cursor-not-allowed transition-colors text-sm cursor-pointer">
                {{ 'dashboard.search_button'|trans }}
            </button>
        </div>
    </section>

    <section aria-label="{{ 'dashboard.search_result'|trans }}">
        <turbo-frame data-testid="search-result" id="search-result" class="mt-8">
            <div class="text-center text-gray-500 py-12">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <p data-testid="search-empty-state" class="mt-2 text-sm">{{ 'dashboard.empty_state'|trans }}</p>
            </div>
        </turbo-frame>
    </section>
</div>
{% endblock %}
